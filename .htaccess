    <IfModule mod_rewrite.c>
        <IfModule mod_negotiation.c>
            Options -MultiViews -Indexes
        </IfModule>

        RewriteEngine On

        # Bloqueia a listagem de diretórios
        Options -Indexes

        # Redireciona tudo para a pasta /public/
        RewriteCond %{REQUEST_URI} !^/public/
        RewriteRule ^(.*)$ /public/$1 [L,QSA]
    </IfModule>
